<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
  <meta name="csrf-token" content="<%= csrfToken %>">
  <title>관리자 페이지</title>
  
  <link rel="manifest" href="/manifest.json">
  <meta name="theme-color" content="#ffffff">
  <link rel="apple-touch-icon" href="/icons/icon-192x192.png">

  <script>
    if ('serviceWorker' in navigator) {
      window.addEventListener('load', () => {
        navigator.serviceWorker.register('/service-worker.js')
          .then(reg => console.log('Service Worker registered.', reg))
          .catch(err => console.log('Service Worker registration failed.', err));
      });
    }
    
    document.addEventListener('DOMContentLoaded', function() {
        PullToRefresh.init({
            mainElement: '.container', 
            triggerElement: 'body',    
            onRefresh: function() { window.location.reload(); },
            distThreshold: 70, distMax: 90, distReload: 60,
            iconArrow: '&#8675;', iconRefreshing: '&hellip;',
            instructionsPullToRefresh: '당겨서 새로고침',
            instructionsReleaseToRefresh: '놓아서 새로고침',
            instructionsRefreshing: '새로고침 중...'
        });
    });

    window.addEventListener('load', function() {
        const isLogin = sessionStorage.getItem('is_login');
        if (!isLogin && document.cookie.includes('connect.sid')) { 
             if (window.location.pathname !== '/login' && window.location.pathname !== '/register') {
                 fetch('/api/logout').then(() => { window.location.href = '/login'; });
             }
        }
        if (window.location.pathname !== '/login') sessionStorage.setItem('is_login', 'true');
    });
  </script>
  
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/pulltorefreshjs/0.1.22/index.umd.min.js"></script>
  
  <style>
    /* === [PWA 최적화] === */
    body {
      padding-top: calc(10px + env(safe-area-inset-top));
      padding-bottom: calc(10px + env(safe-area-inset-bottom));
      padding-left: calc(env(safe-area-inset-left));
      padding-right: calc(env(safe-area-inset-right));
      -webkit-overflow-scrolling: touch;
      overscroll-behavior-y: none;
      user-select: none; -webkit-user-select: none;
      -webkit-tap-highlight-color: transparent;
    }
    input, textarea, select { user-select: text; -webkit-user-select: text; }

    /* === [1. 공통 스타일] === */
    body { font-family: -apple-system, BlinkMacSystemFont, "Malgun Gothic", sans-serif; padding: 20px; background-color: #f4f7f6; margin: 0; }
    * { box-sizing: border-box; }

    .container { max-width: 1000px; margin: 0 auto; background: white; padding: 30px; border-radius: 12px; box-shadow: 0 4px 15px rgba(0,0,0,0.05); }
    
    .header-area { 
        display: flex; justify-content: space-between; align-items: center; 
        position: sticky; top: 0; z-index: 100;
        background-color: #ffffff;
        border-bottom: 2px solid #3498db;
        margin: -30px -30px 30px -30px; 
        padding: 20px 30px;
    }
    h2 { margin: 0; color: #2c3e50; font-size: 24px; }
    
    /* [수정] 섹션 아코디언 스타일 */
    .section { 
        margin-bottom: 20px; /* 간격 조정 */
        padding: 20px 25px; 
        background: #fff; 
        border: 1px solid #e1e4e8; 
        border-radius: 10px; 
        box-shadow: 0 2px 5px rgba(0,0,0,0.02); 
        transition: all 0.3s ease;
    }
    
    .section h3 { 
        margin: 0; 
        color: #34495e; 
        border-left: 5px solid #3498db; 
        padding-left: 12px; 
        font-size: 18px; 
        cursor: pointer; /* 클릭 가능 표시 */
        display: flex; justify-content: space-between; align-items: center;
        user-select: none;
    }

    /* 아코디언 화살표 아이콘 */
    .section h3::after {
        content: '\25BC'; /* 아래쪽 화살표 */
        font-size: 12px;
        color: #999;
        transition: transform 0.3s ease;
    }

    /* 닫힌 상태 (.collapsed) 스타일 */
    .section.collapsed h3::after {
        transform: rotate(-90deg); /* 왼쪽으로 회전 */
    }
    
    /* 내용 영역 (열고 닫힘 대상) */
    .section-content {
        margin-top: 20px;
        display: block; /* 기본: 보임 */
        animation: fadeIn 0.3s ease-in-out;
    }
    
    .section.collapsed .section-content {
        display: none; /* 닫힘: 숨김 */
    }

    @keyframes fadeIn {
        from { opacity: 0; transform: translateY(-5px); }
        to { opacity: 1; transform: translateY(0); }
    }

    .section-desc { font-size: 13px; color: #7f8c8d; margin-bottom: 15px; line-height: 1.5; background: #f8f9fa; padding: 10px; border-radius: 6px; }

    .form-group { margin-bottom: 15px; }
    label { display: block; font-weight: bold; margin-bottom: 6px; font-size: 14px; color: #555; }
    input[type="text"], input[type="password"], select { width: 100%; padding: 12px; border: 1px solid #ddd; border-radius: 6px; font-size: 14px; outline: none; transition: 0.2s; }
    input:focus, select:focus { border-color: #3498db; }
    
    .btn-common { padding: 10px 20px; border-radius: 6px; border: none; cursor: pointer; font-weight: bold; font-size: 14px; transition: 0.2s; }
    .save-btn { background: #27ae60; color: white; width: 100%; margin-top: 10px; }
    .save-btn:hover { background: #219150; }
    .btn-back { background: #95a5a6; color: white; padding: 8px 15px; border-radius: 6px; border: none; cursor: pointer; font-size: 13px; }

    /* 테이블 스타일 */
    .table-responsive { width: 100%; overflow-x: auto; }
    table { width: 100%; border-collapse: collapse; margin-top: 10px; font-size: 13px; min-width: 600px; } 
    th { background: #f1f3f5; padding: 12px; border-bottom: 2px solid #dee2e6; text-align: center; font-weight: bold; color: #495057; white-space: nowrap; }
    td { padding: 12px; border-bottom: 1px solid #f1f3f5; vertical-align: middle; text-align: center; color: #333; }
    tr:hover { background-color: #fafafa; }
    
    .action-cell { white-space: nowrap; }
    .action-btn { padding: 6px 12px; border-radius: 4px; border: none; cursor: pointer; color: white; font-size: 12px; margin: 0 2px; display: inline-block; }
    .btn-edit { background: #3498db; }
    .btn-delete { background: #e74c3c; }
    
    .status-badge { padding: 4px 10px; border-radius: 12px; font-size: 11px; font-weight: bold; color: white; display: inline-block; min-width: 50px; }
    .st-log { background-color: #34495e; padding: 4px 8px; border-radius: 4px; }
    .st-pending { background-color: #f39c12; } 
    .st-approved { background-color: #27ae60; }
    
    .badge { padding: 4px 8px; border-radius: 4px; font-size: 11px; font-weight: bold; color: white; display: inline-block; min-width: 50px; }
    .st-temp { background-color: #95a5a6; } 
    .st-req { background-color: #3498db; } 
    .st-ing { background-color: #f39c12; }
    .st-done { background-color: #27ae60; } 
    .st-paid { background-color: #2c3e50; } 
    .st-reject { background-color: #e74c3c; }

    .doc-prefix { font-size: 11px; color: #888; margin-right: 2px; }
    .doc-serial { font-size: 12px; color: #333; }

    /* 검색바 및 페이지네이션 */
    .search-box { display: flex; gap: 5px; margin-bottom: 10px; }
    .search-input { flex: 1; padding: 8px; font-size: 13px; border: 1px solid #ddd; border-radius: 4px; }
    .search-btn { padding: 8px 15px; background: #2c3e50; color: white; border: none; border-radius: 4px; cursor: pointer; font-size: 13px; }

    .pagination { display: flex; justify-content: center; gap: 5px; margin-top: 15px; }
    .page-btn { padding: 6px 10px; border: 1px solid #ddd; background: white; cursor: pointer; font-size: 12px; border-radius: 4px; }
    .page-btn.active { background: #2c3e50; color: white; border-color: #2c3e50; }
    .page-btn:disabled { color: #ccc; cursor: default; }

    /* 모달 */
    .modal-overlay { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); display: none; justify-content: center; align-items: center; z-index: 1000; }
    .modal-content { background: white; width: 90%; max-width: 500px; padding: 25px; border-radius: 12px; box-shadow: 0 10px 25px rgba(0,0,0,0.2); max-height: 90vh; overflow-y: auto; }
    .modal-header { font-size: 18px; font-weight: bold; margin-bottom: 20px; border-bottom: 1px solid #eee; padding-bottom: 10px; display: flex; justify-content: space-between; align-items: center; }
    .close-btn { cursor: pointer; font-size: 24px; color: #aaa; }
    .modal-footer { margin-top: 25px; text-align: right; display: flex; justify-content: flex-end; gap: 10px; }
    .btn-close { background: #95a5a6; color: white; }
    .btn-confirm { background: #2980b9; color: white; }

    .log-scroll { overflow-y: auto; border: 1px solid #eee; border-radius: 8px; background: #fafafa; }
    
    /* === [2. 모바일 반응형 스타일] === */
    @media screen and (max-width: 600px) {
        body { padding: 10px 0; background-color: #fff; }
        .container { padding: 15px; box-shadow: none; border-radius: 0; }
        
        .header-area { 
            flex-direction: row; margin: -15px -15px 20px -15px; padding: 15px;
            border-bottom: 1px solid #e1e4e8;
        }
        .header-area h2 { font-size: 18px; }
        .btn-back { padding: 6px 10px; font-size: 12px; }

        .section { padding: 15px; margin-bottom: 15px; }
        .section h3 { font-size: 16px; }
        
        table { min-width: 100%; table-layout: fixed; } 
        th, td { padding: 8px 2px; font-size: 12px; }

        .col-doc { width: 70px; } 
        .col-writer { width: 45px; } 
        .col-stat { width: 60px; } 
        .col-manage-user { width: 80px; } 
        .col-manage-doc { width: 40px; }  
        .col-subj { width: auto; } 

        .col-email, .col-gen { display: none; }
        
        .action-btn { padding: 4px 4px; font-size: 11px; margin: 0 1px; }
        
        /* 감사 로그 모바일 "카드 뷰" 스타일 */
        .log-scroll table { min-width: 100% !important; display: block; }
        .log-scroll thead { display: none; }
        .log-scroll tbody { display: block; width: 100%; }
        
        .log-scroll tr {
            display: flex; flex-wrap: wrap; align-items: center;
            border-bottom: 1px solid #e0e0e0; padding: 12px 8px; background: #fff;
            margin-bottom: 5px;
        }
        
        .log-scroll td:nth-child(1) { order: 1; width: 60%; border: none; padding: 0; text-align: left; font-weight: bold; font-size: 14px; color: #333; }
        .log-scroll td:nth-child(1) small { display: none; } 
        .log-scroll td:nth-child(2) { order: 2; width: 40%; border: none; padding: 0; text-align: right; font-size: 11px; color: #888; }
        .log-scroll td:nth-child(4) { order: 3; width: auto; margin-top: 6px; margin-right: auto; border: none; padding: 0; }
        .log-scroll td:nth-child(3) { order: 4; width: auto; margin-top: 6px; border: none; padding: 0; text-align: right; font-size: 11px; color: #aaa; }
        .log-scroll td:nth-child(5) { order: 5; width: 100%; margin-top: 8px; border: none; padding: 8px; text-align: left; font-size: 13px; color: #555; background-color: #f9f9f9; border-radius: 4px; word-break: break-all; line-height: 1.4; }

        .badge { width: 52px; font-size: 10px; padding: 4px 0; white-space: nowrap; }

        .doc-prefix { display: block; margin-bottom: 0; line-height: 1.1; font-size: 10px; color: #555; word-break: keep-all; letter-spacing: -0.5px; }
        .doc-serial { display: block; line-height: 1.2; font-size: 11px; margin-top: 1px; }
    }
  </style>
</head>
<body>
  <div class="container">
    <div class="header-area">
        <h2>관리자 페이지</h2>
        <button onclick="location.href='/list'" class="btn-back">메인으로</button>
    </div>

<div class="section" onclick="toggleSection(this)">
      <h3>1. 시스템 환경 설정</h3>
      <div class="section-content">
          <div class="form-group">
            <label>지출결의서 상단 주소 및 단체명</label>
            <input type="text" id="setting-address" placeholder="예: 경상북도 구미시 ...">
          </div>
          <div class="form-group">
            <label>사이트 접속 URL (메일 링크용)</label>
            <input type="text" id="setting-siteUrl" placeholder="예: http://localhost:8080 (끝에 / 제외)">
          </div>

          <!-- [A-4] 메일(SMTP) 설정 영역 -->
          <hr style="margin:20px 0; border:0; border-top:1px dashed #ccc;">
          <div style="font-weight:bold; color:#34495e; margin-bottom:10px; font-size:15px;">📧 메일(SMTP) 설정</div>
          <div class="section-desc">※ SMTP 설정은 저장 즉시 반영됩니다. 비밀번호는 보안상 마스킹(********) 되어 표시되며, 마스킹 상태로 저장하면 기존 값이 유지됩니다.</div>

          <div class="form-group" style="display:flex; gap:10px;">
              <div style="flex:3;">
                  <label>SMTP 호스트</label>
                  <input type="text" id="setting-smtp-host" placeholder="예: smtp.gmail.com">
              </div>
              <div style="flex:1;">
                  <label>포트</label>
                  <input type="text" id="setting-smtp-port" placeholder="465">
              </div>
          </div>
          <div class="form-group">
              <label>SMTP 계정 (발신 이메일)</label>
              <input type="text" id="setting-smtp-user" placeholder="예: office@example.com">
          </div>
          <div class="form-group">
              <label>SMTP 비밀번호 (또는 앱 비밀번호)</label>
              <input type="password" id="setting-smtp-pass" placeholder="변경할 때만 새 비밀번호를 입력" autocomplete="new-password">
          </div>
          <div class="form-group">
              <label>발신자 표시명</label>
              <input type="text" id="setting-mail-from-name" placeholder="예: 금오공고 총동문회 사무국">
          </div>

          <button class="btn-common save-btn" onclick="saveSettings()">설정 저장</button>
          <button class="btn-common" id="btn-test-mail"
                  style="background:#2980b9; color:white; width:100%; margin-top:8px;"
                  onclick="sendTestMail()">
              테스트 메일 발송 (관리자 본인 수신)
          </button>
      </div>
    </div>

    <div class="section collapsed" onclick="toggleSection(this)">
      <h3>2. 사용자 관리</h3>
      <div class="section-content">
          <div class="section-desc">※ [수정]/[삭제] 가능. [대기]/[잠김] 상태 클릭 시 즉시 승인/해제.</div>
          <div class="table-responsive"> 
            <table>
                <colgroup>
                    <col width="15%"> <col width="25%" class="col-email"> <col width="15%">
                    <col width="10%" class="col-gen"> <col width="15%"> <col width="10%"> <col class="col-manage-user">
                </colgroup>
                <thead>
                <tr>
                    <th>이름</th> <th class="col-email">이메일</th> <th>직책</th>
                    <th class="col-gen">대수</th> <th>상태</th> <th>권한</th> <th>관리</th>
                </tr>
                </thead>
                <tbody id="userTableBody"></tbody>
            </table>
          </div>
      </div>
    </div>

    <div class="section collapsed" onclick="toggleSection(this)">
        <h3>3. 지출결의서 삭제 관리</h3>
        <div class="section-content">
            <div class="section-desc" style="color:#c0392b; background:#fff5f5;">※ 주의: 삭제 시 복구 불가 (첨부파일 포함)</div>
            <div class="search-box">
                <input type="text" id="doc-keyword" class="search-input" placeholder="문서번호, 제목, 기안자로 검색" onkeyup="if(event.key==='Enter') searchDocs()">
                <button class="search-btn" onclick="searchDocs()">검색</button>
            </div>
            <div class="table-responsive">
                <table>
                    <colgroup>
                        <col class="col-doc"> <col class="col-subj"> <col class="col-writer">
                        <col class="col-stat"> <col class="col-manage-doc">
                    </colgroup>
                    <thead>
                        <tr>
                            <th>문서번호</th> <th>제목</th> <th>기안자</th> <th>상태</th> <th>관리</th>
                        </tr>
                    </thead>
                    <tbody id="doc-list-body"></tbody>
                </table>
            </div>
            <div id="doc-pagination" class="pagination"></div>
        </div>
    </div>

    <div class="section collapsed" onclick="toggleSection(this)">
        <h3>4. 감사 로그 (Audit Logs)</h3>
        <div class="section-content">
            <div class="section-desc">활동 기록 조회</div>
            <div class="search-box">
                <input type="text" id="log-keyword" class="search-input" placeholder="사용자, 작업, 내용, IP로 검색" onkeyup="if(event.key==='Enter') searchLogs()">
                <button class="search-btn" onclick="searchLogs()">검색</button>
            </div>
            <div class="log-scroll">
                <table>
                    <thead style="position: sticky; top: 0; z-index: 1;">
                        <tr>
                            <th width="15%">사용자</th> <th width="20%">일시</th> <th width="15%">IP주소</th> 
                            <th width="12%">작업</th> <th width="38%">상세 내용</th> 
                        </tr>
                    </thead>
                    <tbody id="log-table-body"></tbody>
                </table>
            </div>
            <div id="log-pagination" class="pagination"></div>
        </div>
    </div>
  </div>

  <div id="editModal" class="modal-overlay">
    <div class="modal-content">
      <div class="modal-header"><span>사용자 정보 수정</span><span class="close-btn" onclick="closeModal()">&times;</span></div>
      <div class="modal-body">
        <input type="hidden" id="edit-id">
        <div class="form-group"><label>이메일 (수정 불가)</label><input type="text" id="edit-email" disabled style="background:#f1f1f1;"></div>
        <div class="form-group"><label>이름</label><input type="text" id="edit-name"></div>
        <div class="form-group"><label>대수</label><select id="edit-gen"></select></div>
        <div class="form-group"><label>직책</label><input type="text" id="edit-pos"></div>
        <div class="form-group"><label>휴대폰 번호</label><input type="text" id="edit-phone" maxlength="13" oninput="autoHyphen(this)"></div>
        <div class="form-group" style="display:flex; gap:10px;">
            <div style="flex:1;"><label>상태</label><select id="edit-status"><option value="Pending">대기 (Pending)</option><option value="Approved">승인 (Approved)</option></select></div>
            <div style="flex:1;"><label>권한</label><select id="edit-role"><option value="User">일반 (User)</option><option value="Admin">관리자 (Admin)</option></select></div>
        </div>
        <hr style="margin: 15px 0; border:0; border-top:1px dashed #ccc;">
        <div class="form-group"><label>비밀번호 초기화</label><input type="password" id="edit-pw" placeholder="비워두면 변경 안됨"></div>
        <div class="form-group"><label>서명 이미지</label><input type="file" id="edit-sig" accept="image/*"></div>
      </div>
      <div class="modal-footer">
          <button class="btn-common btn-close" onclick="closeModal()">취소</button>
          <button class="btn-common btn-confirm" onclick="submitEdit()">저장하기</button>
      </div>
    </div>
  </div>

  <script>
    function escapeHtml(text) {
        if (!text) return "";
        return text.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;").replace(/"/g, "&quot;").replace(/'/g, "&#039;");
    }

    function getCsrfToken() { return document.querySelector('meta[name="csrf-token"]').getAttribute('content'); }

    let currentDocPage = 1;
    let docKeyword = "";
    let currentLogPage = 1;
    let logKeyword = "";

    window.onload = function() {
        loadSettings();
        loadUsers();
        loadDocs(1); 
        loadAuditLogs(1);
        initGenOptions();
    };

    // [추가] 아코디언 토글 함수
    function toggleSection(element) {
        // 클릭 이벤트가 섹션 내부의 버튼이나 입력창에서 발생했다면 아코디언 동작 방지
        if (event.target.tagName === 'INPUT' || event.target.tagName === 'BUTTON' || event.target.tagName === 'SELECT' || event.target.closest('.section-content')) {
            return;
        }

        const allSections = document.querySelectorAll('.section');
        allSections.forEach(sec => {
            if (sec === element) {
                sec.classList.remove('collapsed');
            } else {
                sec.classList.add('collapsed');
            }
        });
    }

    // ... (이하 기존 스크립트 함수들은 동일하므로 유지) ...
    
    function loadAuditLogs(page) {
        currentLogPage = page || 1;
        fetch(`/api/admin/logs?page=${currentLogPage}&keyword=${encodeURIComponent(logKeyword)}`)
        .then(r => r.json())
        .then(res => {
            const logs = res.logs || [];
            const tbody = document.getElementById('log-table-body');
            
            if (logs.length === 0) { 
                tbody.innerHTML = "<tr><td colspan='5' style='padding:20px; color:#999; text-align:center;'>기록된 로그가 없습니다.</td></tr>"; 
                document.getElementById('log-pagination').innerHTML = "";
                return; 
            }
            
            tbody.innerHTML = logs.map(l => {
                const dateObj = new Date(l.created_at.replace(' ', 'T') + 'Z');
                const dateStr = dateObj.toLocaleString('ko-KR', { month: 'numeric', day: 'numeric', hour: '2-digit', minute:'2-digit' });
                const ip = l.ip_address.replace('::ffff:', '');
                return `<tr>
                    <td><strong>${escapeHtml(l.user_name)}</strong><br><small style="color:#888;">${escapeHtml(l.user_email)}</small></td>
                    <td style="font-size:11px; color:#666;">${dateStr}</td>
                    <td style="font-size:11px; color:#888;">${ip}</td>
                    <td><span class="status-badge st-log">${l.action}</span></td>
                    <td style="text-align:left; line-height:1.4; font-size:12px;">${escapeHtml(l.details)}</td>
                </tr>`;
            }).join('');

            renderPagination('log-pagination', res.page, res.totalPages, loadAuditLogs);
        }).catch(err => console.error("Logs load error:", err));
    }

    function searchLogs() {
        logKeyword = document.getElementById('log-keyword').value;
        loadAuditLogs(1);
    }

    function loadDocs(page) {
        currentDocPage = page || 1;
        fetch(`/api/admin/list?page=${currentDocPage}&keyword=${encodeURIComponent(docKeyword)}`)
        .then(r => r.json())
        .then(res => {
            const docs = res.docs || [];
            const tbody = document.getElementById('doc-list-body');
            
            if (docs.length === 0) { 
                tbody.innerHTML = "<tr><td colspan='5' style='padding:20px; color:#999; text-align:center;'>문서가 없습니다.</td></tr>"; 
                document.getElementById('doc-pagination').innerHTML = "";
                return; 
            }
            
            tbody.innerHTML = docs.map(d => {
                let badgeClass = 'st-temp';
                if(d.stage === '제출완료') badgeClass = 'st-req';
                else if(d.stage === '결재중') badgeClass = 'st-ing';
                else if(d.stage === '최종결재') badgeClass = 'st-done';
                else if(d.stage === '지급완료') badgeClass = 'st-paid';
                else if(d.stage === '반려') badgeClass = 'st-reject';

                let prefix = ''; let serial = d.docNum;
                if (d.docNum.includes('-')) {
                    const parts = d.docNum.split('-');
                    serial = parts.pop(); prefix = parts.join('-') + '-';
                }
                if (d.docNum.startsWith('TEMP-')) { prefix = ''; serial = ''; }

                return `<tr>
                    <td><span class="doc-prefix">${prefix}</span><span class="doc-serial">${serial}</span></td>
                    <td style="text-align:left;">${escapeHtml(d.subject)}</td>
                    <td>${escapeHtml(d.applicant)}</td>
                    <td><span class="badge ${badgeClass}">${d.stage}</span></td>
                    <td class="action-cell"><button class="action-btn btn-delete" onclick="deleteDoc('${d.docNum}')">삭제</button></td>
                </tr>`;
            }).join('');

            renderPagination('doc-pagination', res.page, res.totalPages, loadDocs);
        });
    }

    function searchDocs() {
        docKeyword = document.getElementById('doc-keyword').value;
        loadDocs(1);
    }

    function renderPagination(containerId, currentPage, totalPages, callback) {
        const container = document.getElementById(containerId);
        container.innerHTML = "";
        if (totalPages <= 1) return;

        if (currentPage > 1) {
            const prev = document.createElement('button');
            prev.innerText = "<"; prev.className = "page-btn"; prev.onclick = () => callback(currentPage - 1);
            container.appendChild(prev);
        }

        let start = Math.max(1, currentPage - 2);
        let end = Math.min(totalPages, start + 4);
        if (end - start < 4) start = Math.max(1, end - 4);

        for (let i = start; i <= end; i++) {
            const btn = document.createElement('button');
            btn.innerText = i;
            btn.className = `page-btn ${i === currentPage ? 'active' : ''}`;
            btn.onclick = () => callback(i);
            container.appendChild(btn);
        }

        if (currentPage < totalPages) {
            const next = document.createElement('button');
            next.innerText = ">"; next.className = "page-btn"; next.onclick = () => callback(currentPage + 1);
            container.appendChild(next);
        }
    }

    function initGenOptions() {
      const select = document.getElementById('edit-gen'); select.innerHTML = "";
      const currentYear = new Date().getFullYear();
      const currentTerm = Math.floor((currentYear - 1988) / 2) + 1;
      for (let i = 1; i <= currentTerm + 5; i++) {
        const option = document.createElement('option'); option.value = i; option.text = `제${i}대`; select.appendChild(option);
      }
    }

    function autoHyphen(target) {
      let val = target.value.replace(/[^0-9]/g, '');
      if (val.length > 11) val = val.substr(0, 11);
      let tmp = '';
      if (val.length < 4) tmp = val;
      else if (val.length < 7) tmp = val.substr(0, 3) + '-' + val.substr(3);
      else if (val.length < 11) tmp = val.substr(0, 3) + '-' + val.substr(3, 3) + '-' + val.substr(6);
      else tmp = val.substr(0, 3) + '-' + val.substr(3, 4) + '-' + val.substr(7);
      target.value = tmp;
    }

    function loadSettings() {
        fetch('/api/admin/settings').then(r=>r.json()).then(d=>{
            if(d.address)  document.getElementById('setting-address').value  = d.address;
            if(d.site_url) document.getElementById('setting-siteUrl').value  = d.site_url;

            // [A-4] 메일 설정 필드 로딩. smtp_pass는 서버에서 '********' 로 마스킹되어 옴.
            document.getElementById('setting-smtp-host').value      = d.smtp_host      || '';
            document.getElementById('setting-smtp-port').value      = d.smtp_port      || '';
            document.getElementById('setting-smtp-user').value      = d.smtp_user      || '';
            document.getElementById('setting-smtp-pass').value      = d.smtp_pass      || '';
            document.getElementById('setting-mail-from-name').value = d.mail_from_name || '';
        });
    }

    function saveSettings() {
        const payload = {
            address:        document.getElementById('setting-address').value,
            site_url:       document.getElementById('setting-siteUrl').value,
            // [A-4] 메일 설정 함께 저장.
            smtp_host:      document.getElementById('setting-smtp-host').value,
            smtp_port:      document.getElementById('setting-smtp-port').value,
            smtp_user:      document.getElementById('setting-smtp-user').value,
            // smtp_pass가 '********' 인 경우 서버에서 변경 없음으로 처리됨.
            smtp_pass:      document.getElementById('setting-smtp-pass').value,
            mail_from_name: document.getElementById('setting-mail-from-name').value
        };
        fetch('/api/admin/settings', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'CSRF-Token': getCsrfToken() },
            body: JSON.stringify(payload)
        })
        .then(r => r.json())
        .then(r => {
            Swal.fire('알림', r.msg, r.status === 'Success' ? 'success' : 'error');
            if (r.status === 'Success') {
                // 저장 성공 후 서버가 비밀번호를 마스킹한 값으로 갱신 → 다시 불러와 화면에 반영.
                loadSettings();
            }
        })
        .catch(err => Swal.fire('오류', err.message, 'error'));
    }

    // [A-4] 테스트 메일 발송 (관리자 본인 수신).
    // 현재 DB에 저장된 SMTP 설정 기준으로 실제 발송한다.
    // 저장 전 값이 화면에만 있는 상태라면, 먼저 "설정 저장" 을 누르도록 안내한다.
    function sendTestMail() {
        const btn = document.getElementById('btn-test-mail');
        const originalText = btn.innerText;
        btn.disabled = true;
        btn.innerText = '발송 요청 중...';

        fetch('/api/admin/settings/test-mail', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'CSRF-Token': getCsrfToken() }
        })
        .then(r => r.json())
        .then(r => {
            Swal.fire(
                r.status === 'Success' ? '요청 완료' : '오류',
                r.msg || '처리 결과를 받지 못했습니다.',
                r.status === 'Success' ? 'success' : 'error'
            );
        })
        .catch(err => Swal.fire('오류', err.message, 'error'))
        .finally(() => {
            btn.disabled = false;
            btn.innerText = originalText;
        });
    }

    function loadUsers() {
        fetch('/api/admin/users').then(r => r.json()).then(users => {
            allUsers = users;
            const tbody = document.getElementById('userTableBody');
            tbody.innerHTML = users.map(u => {
                const isLocked = u.locked_until && new Date(u.locked_until) > new Date();
                let bCls = isLocked ? 'st-reject' : (u.status === 'Pending' ? 'st-pending' : 'st-approved');
                let bTxt = isLocked ? '잠김' : (u.status === 'Pending' ? '대기' : '승인');
                let attr = isLocked ? `onclick="unlockUser(${u.id}, '${escapeHtml(u.name)}', this)"` : (u.status === 'Pending' ? `onclick="quickApproveUser(${u.id}, '${escapeHtml(u.name)}', this)"` : '');
                
                return `<tr>
                    <td style="font-weight:bold;">${escapeHtml(u.name)}</td>
                    <td class="col-email">${escapeHtml(u.email)}</td>
                    <td>${escapeHtml(u.position)}</td>
                    <td class="col-gen">${u.generation ? '제'+u.generation+'대' : '-'}</td>
                    <td><span class="status-badge ${bCls}" ${attr} style="cursor:${attr?'pointer':'default'}">${bTxt}</span></td>
                    <td>${u.role}</td>
                    <td class="action-cell">
                        <button class="action-btn btn-edit" onclick="openModal(${u.id})">수정</button>
                        <button class="action-btn btn-delete" onclick="deleteUser(${u.id}, '${escapeHtml(u.name)}')">삭제</button>
                    </td>
                </tr>`;
            }).join('');
        });
    }

    function quickApproveUser(id, name) {
        Swal.fire({ title: '가입 승인', text: `'${name}' 님의 가입을 승인하시겠습니까?`, icon: 'question', showCancelButton: true, confirmButtonColor: '#27ae60', confirmButtonText: '승인하기' }).then((r) => {
            if (r.isConfirmed) {
                fetch('/api/admin/user/approve', { method: 'POST', headers: { 'Content-Type': 'application/json', 'CSRF-Token': getCsrfToken() }, body: JSON.stringify({ id }) })
                .then(r => r.json()).then(res => { Swal.fire('완료', res.msg, 'success'); loadUsers(); });
            }
        });
    }

    function unlockUser(id, name) {
        Swal.fire({ title: '잠금 해제', text: `'${name}' 님의 계정 잠금을 해제하시겠습니까?`, icon: 'question', showCancelButton: true, confirmButtonColor: '#8e44ad', confirmButtonText: '해제하기' }).then((r) => {
            if (r.isConfirmed) {
                fetch('/api/admin/user/unlock', { method: 'POST', headers: { 'Content-Type': 'application/json', 'CSRF-Token': getCsrfToken() }, body: JSON.stringify({ id }) })
                .then(r => r.json()).then(res => { Swal.fire('완료', res.msg, 'success'); loadUsers(); });
            }
        });
    }

    function deleteUser(id, name) {
        Swal.fire({ title: '사용자 삭제', text: `'${name}' 님의 계정을 삭제하시겠습니까? (복구 불가)`, icon: 'warning', showCancelButton: true, confirmButtonColor: '#d33' }).then((r) => {
            if (r.isConfirmed) {
                fetch('/api/admin/user/delete', { method: 'POST', headers: { 'Content-Type': 'application/json', 'CSRF-Token': getCsrfToken() }, body: JSON.stringify({ id }) })
                .then(r => r.json()).then(res => { Swal.fire('삭제됨', res.msg, 'success'); loadUsers(); });
            }
        });
    }

    let allUsers = [];
    function openModal(id) {
        const u = allUsers.find(x => x.id === id);
        if(!u) return;
        document.getElementById('edit-id').value = u.id;
        document.getElementById('edit-email').value = u.email;
        document.getElementById('edit-name').value = u.name;
        document.getElementById('edit-pos').value = u.position;
        document.getElementById('edit-phone').value = u.phone || "";
        document.getElementById('edit-gen').value = u.generation || "";
        document.getElementById('edit-status').value = u.status;
        document.getElementById('edit-role').value = u.role;
        document.getElementById('editModal').style.display = 'flex';
    }
    function closeModal() { document.getElementById('editModal').style.display = 'none'; }

    function submitEdit() {
        const id = document.getElementById('edit-id').value;
        const name = document.getElementById('edit-name').value;
        const pos = document.getElementById('edit-pos').value;
        const phone = document.getElementById('edit-phone').value;
        const gen = document.getElementById('edit-gen').value;
        const status = document.getElementById('edit-status').value;
        const role = document.getElementById('edit-role').value;
        const pw = document.getElementById('edit-pw').value;
        const f = document.getElementById('edit-sig');
        if(!name || !pos) return Swal.fire('알림', '이름과 직책은 필수입니다.', 'warning');
        const p = { id, name, position: pos, phone, generation: gen, status, role, newPassword: pw };
        if (f.files.length > 0) {
            const r = new FileReader();
            r.onload = ev => { p.signatureFile = { data: ev.target.result.split(',')[1], type: f.files[0].type }; sendEditRequest(p); }; r.readAsDataURL(f.files[0]);
        } else sendEditRequest(p);
    }
    
    function sendEditRequest(p) {
        fetch('/api/admin/user/update', { method: 'POST', headers: { 'Content-Type': 'application/json', 'CSRF-Token': getCsrfToken() }, body: JSON.stringify(p) })
        .then(r => r.json()).then(res => {
            if(res.status === 'Success') Swal.fire('완료', res.msg, 'success').then(() => { closeModal(); loadUsers(); }); else Swal.fire('오류', res.msg, 'error');
        });
    }

    function deleteDoc(docNum) {
        Swal.fire({ title: '영구 삭제?', text: "되돌릴 수 없으며 첨부파일도 삭제됩니다.", icon: 'warning', showCancelButton: true, confirmButtonColor: '#d33' }).then((r) => {
            if (r.isConfirmed) {
                fetch('/api/admin/delete_doc', { method: 'POST', headers: { 'Content-Type': 'application/json', 'CSRF-Token': getCsrfToken() }, body: JSON.stringify({ docNum }) })
                .then(r => r.json()).then(res => { Swal.fire('삭제됨', res.msg, 'success'); loadDocs(currentDocPage); });
            }
        });
    }
  </script>
</body>
</html>